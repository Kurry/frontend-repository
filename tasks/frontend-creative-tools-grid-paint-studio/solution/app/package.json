{
  "name": "oracle-static",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
    "verify:build": "npm run build && node -e \"require('fs').accessSync('build/index.html')\"",
    "start": "npx --yes serve -l 3000 build -n"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@felte/validator-zod": "^1.0.18",
    "bits-ui": "^2.18.1",
    "felte": "^1.3.0",
    "phosphor-svelte": "^3.1.0",
    "qrious": "^4.0.2",
    "serve": "14.2.4",
    "svelte-motion": "^0.12.2",
    "zod": "^3.24.1"
  }
}
