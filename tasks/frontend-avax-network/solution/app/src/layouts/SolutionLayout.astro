---
import Layout from "./Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import NewsletterContact from "../components/forms/NewsletterContact.astro";

interface Props {
  title: string;
  headline: string;
  lede: string;
  /** Local offline video under /videos/ (air-gapped). */
  video?: string;
  pillars?: { n: string; title: string; body: string }[];
}

const {
  title,
  headline,
  lede,
  video,
  pillars = [
    { n: "01", title: "Purpose-built performance", body: "Sub-second finality, low fees, and institutional-grade reliability for production workloads." },
    { n: "02", title: "Customizable Layer 1s", body: "Launch sovereign chains with permissioning, gas token, and governance options tailored to your market." },
    { n: "03", title: "Native interoperability", body: "Connect liquidity and messaging across Avalanche L1s without brittle bridges." },
  ],
} = Astro.props;
---

<Layout title={`${title} | Avalanche`} description={lede}>
  <Navigation />
  <main class="pt-[var(--navbar-height)]">
    <section class="group/section animate-in-view relative mx-[var(--padding-base)] mt-[var(--padding-base)] min-h-[70svh] overflow-hidden rounded-[var(--radius-4xl)] bg-white p-[var(--padding-xl)] text-black dark:bg-dark dark:text-white lg:p-[var(--padding-3xl)]">
      {video ? (
        <video
          class="pointer-events-none absolute inset-0 h-full w-full object-cover opacity-40 mix-blend-normal dark:opacity-30"
          src={video}
          muted
          loop
          playsinline
          autoplay
          preload="metadata"
        ></video>
      ) : null}
      <wm-shape id="keep" corner="br" rounded="clamp(1rem, -0.143rem + 1.786vw, 2rem)" corner-rounded="clamp(0.75rem, -0.107rem + 1.339vw, 1.5rem)" corner-size="clamp(4.5rem, -0.071rem + 7.143vw, 8.5rem)" stroke-width="1"></wm-shape>
      <p class="relative z-[1] text-[var(--text-sm)] uppercase tracking-widest text-neutral-500">Scroll to explore page</p>
      <h1 class="relative z-[1] font-aeonik split-heading mt-6 max-w-[18ch] text-[var(--text-6xl)] font-black leading-none">{headline}</h1>
      <p class="relative z-[1] split-text mt-6 max-w-[55ch] text-[var(--text-base)] text-neutral-600 opacity-0 dark:text-neutral-300">{lede}</p>
    </section>

    <section class="group/section animate-in-view mx-[var(--padding-base)] mt-px section-shell">
      <div class="grid grid-cols-1 gap-px md:grid-cols-3">
        {pillars.map((p, i) => (
          <article class="reveal-y rounded-[var(--radius-2xl)] border border-neutral-800 p-5" style={`--index:${i}`}>
            <p class="text-neutral-500 text-[var(--text-sm)]">{p.n}</p>
            <h2 class="font-aeonik mt-2 text-[var(--text-2xl)] font-bold">{p.title}</h2>
            <p class="mt-3 text-[var(--text-sm)] text-neutral-400">{p.body}</p>
          </article>
        ))}
      </div>
    </section>

    <slot />
    <NewsletterContact />
  </main>
  <Footer />
</Layout>
