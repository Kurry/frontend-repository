2414938427,"isMailSended":true,"__v":0},{"_id":"69aede87dc905dca3b6e75d8","size":"1x","date":"2026-03-09T14:51:51.586Z","projectUrl":"readymag.com/6054164","cardLink":"https://readymag.com/6054164","title":"Zerno School","images":{"1x":{"x1":"https://c-p.rmcdn.net/548eb41745f469b4182c7b7c/6054164/Screenshot-dfea8e41-d855-46b9-b195-85f3a0e04ab5_readyscr_304.jpg","x2":"https://c-p.rmcdn.net/548eb41745f469b4182c7b7c/6054164/Screenshot-dfea8e41-d855-46b9-b195-85f3a0e04ab5_readyscr_608.jpg"}},"description":"Online School of Graphic Design and 3D","credits":"Misha Katz","tags":[{"_id":"5de674bc35a5ca000d956d5f","textColor":"#fff","color":"#A6A6A6","title":"Company websites","childs":[],"isTopTag":true,"description":"Cutting-edge company websites","documentTitle":"Examples of business websites made with Readymag","hidden":false,"slug":"business-website"}],"magNum":6054164,"magUser":37884459,"isMailSended":true,"__v":0},{"_id":"69a839fcaaebcbd92ce21eb3","size":"1x","date":"2026-03-04T13:56:12.112Z","projectUrl":"readymag.com/5864979","cardLink":"https://readymag.com/5864979","title":"Aqui, Lá, Acolá","images":{"1x":{"x1":"https://c-p.rmcdn.net/5a03536cc82bee0072b9539c/5864979/Screenshot-1515b405-5270-4bd0-bc2c-3a8852f84d24_readyscr_304.jpg","x2":"https://c-p.rmcdn.net/5a03536cc82bee0072b9539c/5864979/Screenshot-1515b405-5270-4bd0-bc2c-3a8852f84d24_readyscr_608.jpg"}},"description":"In “Aqui Lá Acolá”, photographer Arthur Petrillo (they/them) traces a poetic cartography of belonging across the UK, Brasil, and Japan. Each landscape reflects a different stage of self: the present home, the origin, and the distant mirror. The images are an invitation into an intimate exploration of identity, displacement, and the evolving perception shaped by space, time and Arthur’s own gender journey.","credits":"Arthur Petrillo","tags":[],"magNum":5864979,"magUser":73451637,"isMailSended":true,"__v":0},{"_id":"699efb4c5a37067b44bf27d4","size":"1x","date":"2026-02-25T13:38:20.486Z","projectUrl":"readymag.com/6109197","cardLink":"https://readymag.com/6109197","title":"Kira Muratova's Vers Libre","images":{"1x":{"x1":"https://c-p.rmcdn.net/53c7c0bdd413204b1b115358/6109197/Screenshot-f42ff421-db24-4689-bf09-7e76f98f164c_readyscr_304.jpg","x2":"https://c-p.rmcdn.net/53c7c0bdd413204b1b115358/6109197/Screenshot-f42ff421-db24-4689-bf09-7e76f98f164c_readyscr_608.jpg"}},"description":"Kira Muratova’s cinema has been described as grotesque, infernal, feminist, cruel, apolitical, and intimate, yet in any case it leaves us with far more questions than answers.","credits":"elena saharova","tags":[{"_id":"5de674bc35a5ca000d956d60","textColor":"#fff","color":"#008BFF","title":"Editorials","childs":[],"isTopTag":true,"description":"Multimedia editorials designed to impress you","documentTitle":"Examples of Readymag editorials","hidden":false,"slug":"editorial"}],"magNum":6109197,"magUser":92166019,"isMailSended":true,"__v":0}]