<!doctype html>
<html><head><meta charset="utf-8"><title>offline</title></head>
<body>
<script>
/* Intentional air-gap stub: answers GetLoggedUser so Viewer header can set isUserLoaded */
window.addEventListener("message", function (e) {
  if (e.data === "GetLoggedUser") {
    try {
      parent.postMessage(JSON.stringify({ event: "user", message: null }), "*");
    } catch (err) {}
  }
});
</script>
</body>
</html>
