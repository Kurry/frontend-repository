---
import App from '../components/App.svelte';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Dare Night - A party card game" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%23010101'/%3E%3Cpath d='M18 14h14c11 0 18 7 18 18S43 50 32 50H18V14zm12 9v18h2c6 0 9-3 9-9s-3-9-9-9h-2z' fill='%2334CDE3'/%3E%3C/svg%3E" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <title>Dare Night</title>
  </head>
  <body class="min-h-screen" style="background-color: var(--color-bg);">
