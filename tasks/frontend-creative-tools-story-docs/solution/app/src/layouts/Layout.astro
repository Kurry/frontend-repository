---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <div id="app">
      <slot />
    </div>

    <!-- Required WebMCP Bridge placeholder (if tests run it in same environment) -->
  </body>
</html>
