            <svg viewBox="0 0 31 30" fill="none" class="h-2/3 text-black dark:text-white">
              <path d="M11.1013 5.06017C11.1013 8.89118 12.6232 12.5653 15.3321 15.2742C18.041 17.9831 21.7151 19.505 25.5462 19.505C27.0067 19.505 28.4143 19.2899 29.7416 18.8871C28.8412 21.8522 27.0111 24.4492 24.5216 26.2946C22.0321 28.1399 19.0151 29.1357 15.9163 29.1349C12.4509 29.1374 9.10008 27.894 6.47516 25.6315C3.85024 23.3691 2.12617 20.2384 1.61746 16.8105C1.10875 13.3827 1.84932 9.88618 3.70406 6.95892C5.55879 4.03166 8.40408 1.86874 11.7208 0.864746C11.3091 2.22512 11.1003 3.63883 11.1013 5.06017Z" stroke="currentcolor" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <span class="sr-only">toggle dark mode</span>
        </button>
        <a
          href="https://build.avax.network"
          class="group/button button arrow w-full hidden lg:flex dark:fill-red dark:after:bg-black dark:text-white dark:hover:fill-white dark:hover:text-black"
          target="_blank"
          rel="noopener"
        >
          <wm-shape
            id="button"
            rounded="clamp(0.625rem, 0.196rem + 0.67vw, 1rem)"
            rounded-mobile="clamp(0.875rem, 0.803rem + 0.309vw, 1rem)"
            corner-rounded="clamp(0.25rem, 0.107rem + 0.223vw, 0.375rem)"
            corner-rounded-mobile="clamp(0.313rem, 0.276rem + 0.154vw, 0.375rem)"
            corner-size="clamp(1.125rem, -0.161rem + 2.009vw, 2.25rem)"
            corner-size-mobile="clamp(2rem, 1.855rem + 0.617vw, 2.25rem)"
          ></wm-shape>
          {" Start Building "}
        </a>
        <button
          id="toggle-menu-button"
          type="button"
          class="group/button button aspect-square flex-col justify-center gap-1.5 px-sm group-[.opened]/navigation:fill-red lg:hidden dark:fill-red dark:group-[.opened]/navigation:fill-white"
          aria-label="toggle mobile menu"
          aria-expanded="false"
        >
