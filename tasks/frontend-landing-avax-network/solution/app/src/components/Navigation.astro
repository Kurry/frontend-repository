              class="arrow font-aeonik text-[length:var(--text-sm)] font-semibold text-black no-underline transition-colors hover:text-red dark:text-neutral-200"
              style="font-size: var(--text-sm); line-height: 1;"
              aria-label="link to Grants"
            >
              Grants
              <span class="sr-only">link to Grants</span>
            </a>
          </li>
        </ul>
