                <div class="rounded-2xl border border-neutral-200 bg-white p-4 shadow-xl dark:border-neutral-800 dark:bg-dark">
                  {menu.links.map((l) => (
                    <a
                      href={l.href}
                      class="nav-mega-link block rounded-lg px-3 py-2 text-[var(--text-sm)] text-neutral-600 transition-colors hover:bg-neutral-50 hover:text-red dark:text-neutral-300 dark:hover:bg-neutral-900"
                      target={l.external ? "_blank" : undefined}
                      rel={l.external ? "noopener" : undefined}
                    >
                      {l.label}
