          class="relative flex cursor-pointer flex-row items-center gap-1 rounded-full border border-neutral-200 p-1 after:absolute after:top-0.5 after:left-0.5 after:aspect-square after:h-[calc(100%-0.25rem)] after:rounded-full after:bg-dark after:transition-all after:duration-300 after:ease-out-quart dark:border-neutral-800 dark:after:translate-x-full dark:after:bg-neutral-800"
        >
