            rounded="clamp(0.563rem, 0.063rem + 0.781vw, 1rem)"
            rounded-mobile="clamp(0.875rem, 0.803rem + 0.309vw, 1rem)"
            corner-rounded="clamp(0.188rem, -0.027rem + 0.335vw, 0.375rem)"
            corner-rounded-mobile="clamp(0.313rem, 0.276rem + 0.154vw, 0.375rem)"
            corner-size="clamp(1.125rem, -0.161rem + 2.009vw, 2.25rem)"
            corner-size-mobile="clamp(1.125rem, 0.908rem + 0.926vw, 1.5rem)"
          ></wm-shape>
          <span class="h-px w-1/2 bg-white duration-300 ease-out-cubic transform-[background-color,translate] group-[.opened]/navigation:translate-y-1.5 group-[.opened]/navigation:rotate-45 dark:group-[.opened]/navigation:bg-black"></span>
          <span class="h-px w-1/2 bg-white transition-opacity duration-150 ease-out-cubic group-[.opened]/navigation:opacity-0 dark:group-[.opened]/navigation:bg-black"></span>
          <span class="h-px w-1/2 bg-white duration-300 ease-out-cubic transform-[background-color,translate] group-[.opened]/navigation:-translate-y-[7px] group-[.opened]/navigation:-rotate-45 dark:group-[.opened]/navigation:bg-black"></span>
          <span class="sr-only">toggle mobile menu</span>
        </button>
      </div>
    </div>
  </div>

  <div class="menu-panel lg:hidden">
    <div class="menu-inner space-y-2 bg-white px-[var(--padding-md)] py-[var(--padding-base)] dark:bg-neutral-950">
      {menus.map((menu) => (
        <div class="accordion border-b border-neutral-200 dark:border-neutral-800">
          <button type="button" class="flex w-full items-center justify-between py-3 font-aeonik text-[var(--text-base)] font-semibold text-black dark:text-white">{menu.label}</button>
          <div class="accordion-body">
            <div class="space-y-1 pb-3">
              {menu.links.map((l) => (
                <a href={l.href} class="block py-1.5 text-[var(--text-sm)] text-neutral-500 hover:text-red dark:text-neutral-400">{l.label}</a>
              ))}
            </div>
          </div>
        </div>
      ))}
      <a href="https://build.avax.network/grants" class="block py-2 font-aeonik text-[var(--text-base)] font-semibold text-black hover:text-red dark:text-white" target="_blank" rel="noopener">Grants</a>
      <a href="https://build.avax.network" class="btn btn-primary mt-4 w-full" target="_blank" rel="noopener">Start Building</a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById("navigation");
  const overlay = document.getElementById("overlay");
  const toggle = document.getElementById("toggle-menu-button");
  const themeToggle = document.getElementById("theme-toggle-button");
  const inners = document.querySelectorAll<HTMLElement>(".menu-inner");
  const accordions = document.querySelectorAll(".accordion");
  const menuBg = document.getElementById("menu-background");
  const navItems = document.querySelectorAll(".nav-item");

  const setMaxHeight = () => {
    let max = 0;
    inners.forEach((el) => { max = Math.max(max, el.clientHeight); });
    nav?.style.setProperty("--max-height", `${max + 32}px`);
  };

  themeToggle?.addEventListener("click", () => {
    const root = document.documentElement;
    // In-memory only — no localStorage (behavioral state resets on reload).
    root.classList.toggle("dark");
  });

  toggle?.addEventListener("click", () => {
    accordions.forEach((a) => a.classList.remove("opened"));
    nav?.classList.toggle("opened");
    document.documentElement.classList.toggle("scroll-disabled");
    overlay?.classList.toggle("visible");
    const open = nav?.classList.contains("opened");
    toggle.setAttribute("aria-expanded", open ? "true" : "false");
  });

  overlay?.addEventListener("click", () => {
    nav?.classList.remove("opened");
    overlay.classList.remove("visible");
    document.documentElement.classList.remove("scroll-disabled");
    toggle?.setAttribute("aria-expanded", "false");
  });

  accordions.forEach((acc) => {
    acc.querySelector("button")?.addEventListener("click", () => {
      acc.classList.toggle("opened");
      setMaxHeight();
    });
  });

  const showMenuBg = () => {
    menuBg?.classList.add("is-open");
  };
  const hideMenuBg = () => {
    menuBg?.classList.remove("is-open");
  };
  navItems.forEach((item) => {
    item.addEventListener("mouseenter", showMenuBg);
    item.addEventListener("mouseleave", hideMenuBg);
  });

  setMaxHeight();
  window.addEventListener("resize", setMaxHeight);
</script>
