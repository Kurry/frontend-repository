---
const cols = [
  {
    title: "About",
    span2: true,
    links: [
      { label: "About Astra", href: "/about" },
      { label: "Astra Foundation", href: "/about/foundation" },
      { label: "Blog", href: "/about/blog" },
      { label: "Contact Us", href: "/about/contact-us" },
      { label: "Press", href: "/about/press" },
      { label: "Astra Labs", href: "https://www.avalabs.org/" },
      { label: "Sustainability Metrics", href: "https://sustainability.avax.network/" },
      { label: "Merch Store", href: "https://shop.avax.network/" },
      { label: "Support", href: "https://support.avax.network/en/" },
    ],
  },
  {
    title: "Build",
    span2: true,
    links: [
      { label: "Developer Hub", href: "/build/developer-hub" },
      { label: "Validators", href: "/build/validators" },
      { label: "Documentation", href: "https://build.avax.network/docs" },
      { label: "Academy", href: "https://build.avax.network/academy" },
      { label: "Tools", href: "https://build.avax.network/tools" },
      { label: "Grants", href: "https://build.avax.network/grants" },
      { label: "Integrations", href: "https://build.avax.network/integrations" },
      { label: "Hackathons", href: "https://build.avax.network/hackathons" },
      { label: "Builder Console", href: "https://build.avax.network/console" },
      { label: "Intro to Blockchain", href: "https://elevate.avax.network/" },
      { label: "Astra Ecosystem", href: "https://core.app/discover" },
      { label: "Astra Stats", href: "https://build.avax.network/stats/overview" },
      { label: "Astra Status", href: "https://status.avax.network/" },
      { label: "Burned ASTRA", href: "https://burnedavax.com/" },
      { label: "AstraTrace", href: "https://snowtrace.io/" },
      { label: "Staking Metrics", href: "https://stats.avax.network/dashboard/staking/" },
      { label: "Validator Health Check", href: "https://stats.avax.network/dashboard/validator-health-check/" },
      { label: "Bug Bounty", href: "https://immunefi.com/bug-bounty/Astra/information/" },
      { label: "Support", href: "https://support.avax.network/en/" },
      { label: "Astra Explorer", href: "https://explorer.avax.network/" },
    ],
  },
  {
    title: "Solutions",
    links: [
      { label: "Enterprise", href: "/enterprise" },
      { label: "Decentralized Finance (DeFi)", href: "/defi" },
      { label: "NFTs, Arts & Culture", href: "/nft" },
      { label: "Infrastructure and Tooling", href: "/infrastructure" },
      { label: "Institutions and Capital Markets", href: "/institutions" },
      { label: "Gaming", href: "/gaming" },
      { label: "Astra Evergreen", href: "https://evergreen.avax.network" },
    ],
  },
  {
    title: "Community",
    links: [
      { label: "Community Hub", href: "/community-hub" },
      { label: "Events", href: "/community-hub/events" },
      { label: "Network Report Newsletter", href: "/community-hub/newsletter" },
      { label: "Ecosystem", href: "https://core.app/discover" },
      { label: "Build", href: "https://build.avax.network" },
      { label: "Astra Team1", href: "https://www.team1.network/" },
      { label: "Community Chat", href: "https://discord.com/invite/avax" },
      { label: "Astra Student Program", href: "https://build.avax.network/students" },
    ],
  },
  {
    title: "Legal",
    links: [
      { label: "Terms of Use", href: "/legal/terms-of-use" },
      { label: "Privacy Policy", href: "/legal/privacy-policy" },
      { label: "Trademark Usage Policy", href: "/legal/trademark-usage-policy" },
      { label: "Important Notice", href: "/legal/important-notice" },
      { label: "Forum Notice and Disclaimer", href: "/legal/forum-notice-and-disclaimer" },
      { label: "Astra Wallet Terms of Use", href: "#footer" },
    ],
  },
  {
    title: "Socials",
    links: [
      { label: "Code Forge", href: "https://github.com/ava-labs" },
      { label: "Community Chat", href: "https://discord.gg/avax" },
      { label: "Live Updates", href: "https://x.com/avax" },
      { label: "Professional Network", href: "https://www.linkedin.com/company/Astraavax/" },
      { label: "Video Channel", href: "https://www.youtube.com/Astraavax" },
    ],
  },
];

const wordmarks = [0, 1, 2, 3];
---

<footer id="footer" class="relative z-1 -mt-px w-screen lg:min-h-[calc(100svh-var(--navbar-height)+1px)]">
  <div
    class="group/section animate-in-view relative flex h-full w-full flex-col items-stretch justify-between gap-[var(--gap-xl)] rounded-[var(--radius-4xl)] fill-black px-0 pt-[var(--padding-3xl)] pb-[var(--padding-xl)]"
  >
    <wm-shape
      rounded="clamp(1rem, -0.143rem + 1.786vw, 2rem)"
      rounded-mobile="clamp(1rem, 0.421rem + 2.469vw, 2rem)"
      corner-rounded="clamp(0.75rem, -0.107rem + 1.339vw, 1.5rem)"
      corner-rounded-mobile="clamp(0.75rem, -0.107rem + 1.339vw, 1.5rem)"
      corner-size="clamp(4.5rem, -0.071rem + 7.143vw, 8.5rem)"
      corner-size-mobile="clamp(3.5rem, 0.606rem + 12.346vw, 8.5rem)"
      corner="tr"
    ></wm-shape>

    <div class="grid grid-cols-1 place-items-stretch gap-[var(--gap-md)] px-[var(--padding-md)] lg:grid-cols-[2fr_5fr] lg:gap-0 lg:pr-[var(--padding-2xl)] lg:pl-[var(--padding-3xl)]">
      <div
        class="flex size-[clamp(2rem,1.421rem+2.469vw,3rem)] shrink-0 items-center justify-center rounded-full bg-transparent text-red lg:size-[clamp(3rem,1.857rem+1.786vw,4rem)]"
      >
        <svg viewBox="0 0 722 628" class="w-1/2" aria-hidden="true">
          <path
            d="M548.831 381.485C560.015 362.435 587.792 362.435 598.853 381.485L717.703 584.525C728.887 603.575 714.876 627.296 692.63 627.296H454.932C432.686 627.296 418.797 603.575 429.859 584.525L548.831 381.485Z"
            fill="currentcolor"></path>
          <path
            d="M477.034 246.295C487.849 227.367 487.849 204.015 477.034 184.965L379.57 14.9872C368.631 -4.06311 341.346 -4.06311 330.408 14.9872L4.21765 584.407C-6.7209 603.457 6.92156 627.301 28.7987 627.301H223.603C245.358 627.301 265.391 615.625 276.207 596.697L476.911 246.295H477.034Z"
            fill="currentcolor"></path>
        </svg>
      </div>

      <div class="grid flex-1 grid-cols-1 place-items-start gap-[var(--gap-xl)] sm:grid-cols-4 sm:grid-rows-[auto_1fr]">
        {
          cols.map((col, i) => (
            <ul class:list={[col.span2 && "row-span-2", "reveal-y"]} style={`--index:${i}`}>
              <li>
                <h2 class="mb-[clamp(0.25rem,-0.036rem+0.446vw,0.5rem)] text-2xl text-white uppercase"> {col.title} </h2>
              </li>
              {col.links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    class="relative font-aeonik leading-none font-bold text-neutral-500 no-underline transition-mode hover:text-red"
                    target={l.href.startsWith("http") ? "_blank" : "_self"}
                    rel={l.href.startsWith("http") ? "noopener" : undefined}
                  >
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          ))
        }
      </div>
    </div>

    <div id="marquee" class="marquee flex w-full max-w-full select-none flex-row overflow-clip" style="--duration: 5s; --direction: normal;">
      <div class="marquee-content flex h-full shrink-0 items-center justify-start gap-px pr-16 lg:pr-32" style="--duration: 5s; --direction: normal;">
        {
          wordmarks.map((_, i) => (
            <svg viewBox="0 0 640 98" fill="none" class="h-32 text-white lg:h-auto lg:w-[calc(100vw-var(--padding-3xl)*2)]" aria-hidden={i === 0 ? undefined : "true"} role={i === 0 ? "img" : undefined} aria-label={i === 0 ? "Astra Network wordmark" : undefined}>
              <text x="0" y="78" fill="currentcolor" font-family="aeonik, system-ui, sans-serif" font-weight="900" font-size="84" letter-spacing="18">ASTRA</text>
            </svg>
          ))
        }
      </div>
    </div>
    <p class="self-start px-[var(--padding-md)] text-neutral-200 lg:pr-[var(--padding-2xl)] lg:pl-[var(--padding-3xl)]">
      Created by Wonder Makers
    </p>
  </div>
</footer>
