---

<section id="blog" class="relative w-full">
  <div
    class="group/section animate-in-view corner-background-top relative flex w-full flex-col items-stretch justify-start gap-[var(--gap-xl)] rounded-[var(--radius-4xl)] fill-white px-[var(--padding-md)] py-[var(--padding-3xl)] transition-mode lg:p-[var(--padding-3xl)] lg:pr-[var(--padding-md)] dark:fill-dark"
  >
    <wm-shape
      rounded="clamp(1rem, -0.143rem + 1.786vw, 2rem)"
      rounded-mobile="clamp(1rem, 0.421rem + 2.469vw, 2rem)"
      corner-rounded="clamp(0.75rem, -0.107rem + 1.339vw, 1.5rem)"
      corner-rounded-mobile="clamp(0.75rem, -0.107rem + 1.339vw, 1.5rem)"
      corner-size="clamp(4.5rem, -0.071rem + 7.143vw, 8.5rem)"
      corner-size-mobile="clamp(3.5rem, 0.606rem + 12.346vw, 8.5rem)"
      stroke-width="1"
      corner="tl"
    ></wm-shape>

    <div
      class="grid grid-cols-1 place-items-start gap-[var(--gap-xl)] overflow-x-clip border-b border-neutral-200 pb-[var(--padding-xl)] transition-mode lg:grid-cols-[2fr_5fr] lg:grid-rows-1 lg:place-items-end dark:border-neutral-800"
    >
      <div class="flex flex-col items-end justify-end gap-[var(--gap-xl)] sm:flex-row-reverse sm:items-center lg:col-start-2 lg:row-start-1 lg:items-end">
        <svg
          viewBox="0 0 120 120"
          fill="none"
          class="w-[clamp(4rem,1.975rem+8.642vw,7.5rem)] shrink-0 translate-x-[calc(100%+1px)] stroke-[1rem] transition-move group-[.visible]/section:translate-x-0 group-[.visible]/section:delay-500 lg:w-[clamp(4rem,0rem+6.25vw,7.5rem)] lg:self-start dark:text-white"
          aria-hidden="true"
        >
          <path d="M6 6L59.6641 60.5L6 114M114 6L75.875 44.125M114 114L75.875 76.875" fill="none" stroke="currentcolor"></path>
        </svg>
        <h2 class="h4 max-w-256 split-heading text-balance text-right leading-none uppercase dark:text-white" style="line-height: 1">
          News & Stories from the Avalanche Network
        </h2>
      </div>
    </div>

    <div class="flex flex-col items-stretch justify-start gap-y-2">
      <div class="flex flex-row items-center justify-start gap-[var(--gap-xl)]">
        <div class="flex flex-1 flex-row items-center justify-start gap-[var(--gap-xl)]">
          <h3 class="h6 hidden w-full max-w-[clamp(20rem,6.979rem+55.556vw,42.5rem)] uppercase lg:block lg:max-w-[clamp(25rem,-0.143rem+39.286vw,47rem)]">
            Featured
          </h3>
          <h3 class="h6 flex-1 uppercase">News</h3>
        </div>
        <div id="blog-labels" class="flex flex-row items-center justify-end gap-0.5">
          <button type="button" class="group/button button arrow empty swiper-blog-button-prev rotate-180" aria-label="Previous articles">
            <wm-shape
              id="button"
              rounded="clamp(0.625rem, 0.196rem + 0.67vw, 1rem)"
              rounded-mobile="clamp(0.875rem, 0.803rem + 0.309vw, 1rem)"
              corner-rounded="clamp(0.25rem, 0.107rem + 0.223vw, 0.375rem)"
              corner-rounded-mobile="clamp(0.313rem, 0.276rem + 0.154vw, 0.375rem)"
              corner-size="clamp(1.125rem, -0.161rem + 2.009vw, 2.25rem)"
              corner-size-mobile="clamp(2rem, 1.855rem + 0.617vw, 2.25rem)"
            ></wm-shape>
          </button>
          <button type="button" class="group/button button arrow empty swiper-blog-button-next" aria-label="Next articles">
            <wm-shape
              id="button"
              rounded="clamp(0.625rem, 0.196rem + 0.67vw, 1rem)"
              rounded-mobile="clamp(0.875rem, 0.803rem + 0.309vw, 1rem)"
              corner-rounded="clamp(0.25rem, 0.107rem + 0.223vw, 0.375rem)"
              corner-rounded-mobile="clamp(0.313rem, 0.276rem + 0.154vw, 0.375rem)"
              corner-size="clamp(1.125rem, -0.161rem + 2.009vw, 2.25rem)"
              corner-size-mobile="clamp(2rem, 1.855rem + 0.617vw, 2.25rem)"
            ></wm-shape>
          </button>
        </div>
      </div>

      <div class="flex w-[calc(100%+var(--padding-md))] flex-row items-stretch justify-start">
        <div
          id="swiper-blog"
          class="swiper group/swiper relative w-full translate-x-[100vw] overflow-visible! transition-transform duration-0 delay-0 ease-out-quart group-[.visible]/section:translate-x-0 group-[.visible]/section:duration-2000 !pr-[var(--padding-md)]"
        >
          <div class="swiper-wrapper group/swiperWrapper relative">
            {
              posts.map((p, i) => (
                <a
                  href={p.href}
                  class:list={[
                    "group article-card swiper-slide !flex shrink-0 cursor-grab flex-col items-stretch justify-start overflow-hidden rounded-2xl border border-neutral-200 !transition-all duration-300 ease-out-cubic hover:bg-neutral-50 active:cursor-grabbing dark:border-neutral-800 dark:hover:bg-neutral-900",
                    i === 0
                      ? "w-full max-w-[clamp(20rem,6.979rem+55.556vw,42.5rem)] lg:max-w-[clamp(25rem,-0.143rem+39.286vw,47rem)]"
                      : "max-w-[clamp(20rem,17.83rem+9.259vw,23.75rem)] lg:max-w-[clamp(12.875rem,0.446rem+19.42vw,23.75rem)] -ml-px",
                  ]}
                >
                  <div class="relative aspect-video w-full shrink-0 overflow-hidden rounded-b-2xl">
                    <wm-shape
                      id="article-card-cover"
                      rounded="clamp(0.5rem, -0.071rem + 0.893vw, 1rem)"
                      rounded-mobile="1rem"
                      corner-rounded="clamp(0.5rem, -0.071rem + 0.893vw, 1rem)"
                      corner-rounded-mobile="clamp(0.75rem, -0.107rem + 1.339vw, 1.5rem)"
                      corner-size="clamp(4.5rem, -0.071rem + 7.143vw, 8.5rem)"
                      corner-size-mobile="clamp(3.5rem, 0.606rem + 12.346vw, 8.5rem)"
                      image={p.img}
                    ></wm-shape>
                  </div>
                  <div class="!flex flex-1 flex-col items-start justify-between gap-[var(--gap-md)] p-8 pt-4 lg:p-[var(--padding-md)] lg:pt-[var(--padding-base)]">
                    <div class="flex w-full flex-col items-start justify-start gap-1">
                      <div class="mb-[var(--gap-xs)] flex flex-row flex-wrap items-center justify-start gap-[var(--gap-xs)]">
                        {p.tags.map((t) => (
                          <span
                            class:list={[
                              "xs shrink-0 rounded-full px-[var(--padding-base)] py-[var(--padding-xs)] font-aeonik font-bold select-none transition-mode",
                              t.tone === "solid"
                                ? "bg-red-700 text-white"
                                : "border border-neutral-200 text-black dark:border-neutral-800 dark:text-white",
                            ]}
                          >
                            {t.label}
                          </span>
                        ))}
                      </div>
                      <p class="text-xs text-neutral-500 transition-mode dark:text-neutral-300">{p.meta}</p>
                      <h4 class="mt-1 line-clamp-4 text-ellipsis text-xl/normal capitalize transition-mode">{p.title}</h4>
                      <p class="sm mt-[var(--gap-xs)] line-clamp-3 text-ellipsis leading-[150%] text-neutral-500 transition-mode dark:text-neutral-300">
                        {p.excerpt}
                      </p>
                    </div>
                    <span class="group/button button arrow secondary pointer-events-none inline-flex">
                      <wm-shape
                        id="button"
                        rounded="clamp(0.625rem, 0.196rem + 0.67vw, 1rem)"
                        rounded-mobile="clamp(0.875rem, 0.803rem + 0.309vw, 1rem)"
                        corner-rounded="clamp(0.25rem, 0.107rem + 0.223vw, 0.375rem)"
                        corner-rounded-mobile="clamp(0.313rem, 0.276rem + 0.154vw, 0.375rem)"
                        corner-size="clamp(1.125rem, -0.161rem + 2.009vw, 2.25rem)"
                        corner-size-mobile="clamp(2rem, 1.855rem + 0.617vw, 2.25rem)"
                      ></wm-shape>
                      Read More
                    </span>
                  </div>
                </a>
              ))
            }
          </div>
        </div>
      </div>

      <a href="/about/blog" class="group/button button arrow transparent inline-flex w-auto self-start">
        <wm-shape
          id="button"
          rounded="clamp(0.625rem, 0.196rem + 0.67vw, 1rem)"
          rounded-mobile="clamp(0.875rem, 0.803rem + 0.309vw, 1rem)"
          corner-rounded="clamp(0.25rem, 0.107rem + 0.223vw, 0.375rem)"
          corner-rounded-mobile="clamp(0.313rem, 0.276rem + 0.154vw, 0.375rem)"
          corner-size="clamp(1.125rem, -0.161rem + 2.009vw, 2.25rem)"
          corner-size-mobile="clamp(2rem, 1.855rem + 0.617vw, 2.25rem)"
        ></wm-shape>
        View More
      </a>
    </div>
  </div>
</section>

<section id="solutions" class="relative w-full">
  <div
    class="group/section animate-in-view corner-background-bottom relative flex w-full flex-col items-stretch justify-start gap-[var(--gap-xl)] rounded-[var(--radius-4xl)] fill-white px-[var(--padding-md)] py-[var(--padding-3xl)] transition-mode lg:p-[var(--padding-3xl)] lg:pr-[var(--padding-md)] dark:fill-dark"
  >
    <wm-shape
      rounded="clamp(1rem, -0.143rem + 1.786vw, 2rem)"
      rounded-mobile="clamp(1rem, 0.421rem + 2.469vw, 2rem)"
      corner-rounded="clamp(0.75rem, -0.107rem + 1.339vw, 1.5rem)"
      corner-rounded-mobile="clamp(0.75rem, -0.107rem + 1.339vw, 1.5rem)"
      corner-size="clamp(4.5rem, -0.071rem + 7.143vw, 8.5rem)"
      corner-size-mobile="clamp(3.5rem, 0.606rem + 12.346vw, 8.5rem)"
      stroke-width="1"
      corner="bl"
    ></wm-shape>
    <div
      class="grid grid-cols-1 place-items-start gap-[var(--gap-xl)] overflow-x-clip border-b border-neutral-200 pb-[var(--padding-xl)] transition-mode lg:grid-cols-[5fr_2fr] dark:border-neutral-800"
    >
      <div class="flex flex-col items-start justify-end gap-[var(--gap-xl)] sm:flex-row sm:items-center lg:items-end">
        <svg
          viewBox="0 0 120 120"
          fill="none"
          class="w-[clamp(4rem,1.975rem+8.642vw,7.5rem)] shrink-0 -translate-x-[calc(100%+1px)] stroke-[1rem] transition-move group-[.visible]/section:translate-x-0 group-[.visible]/section:delay-500 lg:w-[clamp(4rem,0rem+6.25vw,7.5rem)] lg:self-start dark:text-white"
          aria-hidden="true"
        >
          <path d="M-4 68.3594C27 68.3594 52 93.3594 52 124.359" stroke="currentcolor" fill="none"></path>
          <path d="M68 124.359C68 93.3594 93 68.3594 124 68.3594" stroke="currentcolor" fill="none"></path>
          <path d="M124 52.3594C93 52.3594 68 27.3594 68 -3.64063" stroke="currentcolor" fill="none"></path>
          <path d="M52 -3.64062C52 27.3594 27 52.3594 -4.00001 52.3594" stroke="currentcolor" fill="none"></path>
        </svg>
        <h2 class="h4 max-w-256 split-heading text-balance text-left leading-none uppercase dark:text-white">
          Avalanche Solutions
        </h2>
      </div>
    </div>
    <div class="grid grid-cols-1 place-items-start gap-[var(--gap-xl)] lg:grid-cols-[2fr_5fr] lg:place-items-stretch">
      <p class="split-text leading-[135%]">
        Avalanche empowers founders, businesses and institutions across industries, both Web2 and crypto-native, to build anything they want, any way they want. Take control with the best custom scaling solutions and supportive developer community on Avalanche.
      </p>
      <div class="grid grid-cols-1 place-items-stretch md:grid-cols-2 lg:col-start-2">
        {
          solutions.map((s, i) => (
            <a
              href={s.href}
              style={`--index: ${i};`}
              class="group/button group/card relative -mt-px -ml-px flex h-auto min-h-[7.25rem] w-full shrink-0 flex-row items-center justify-start gap-[var(--gap-base)] overflow-clip p-[var(--padding-xs)] font-normal no-underline transition-move translate-y-1/2 before:absolute before:inset-0 before:rounded-2xl before:border before:border-neutral-200 before:bg-transparent before:transition-mode group-[.visible]/section:translate-y-0 group-[.visible]/section:duration-[calc(2000ms+(200ms*var(--index)))] hover:before:bg-neutral-50 dark:before:border-neutral-800 dark:hover:before:bg-neutral-900"
            >
              <div class="relative flex aspect-square h-full shrink-0 flex-row items-center justify-center overflow-hidden rounded-2xl bg-neutral-500">
                <img
                  src={s.img}
                  alt={s.title}
                  loading="lazy"
                  decoding="async"
                  width="300"
                  height="300"
                  class="absolute inset-0 h-full w-full object-cover"
                />
                <h3 class="h5 relative text-white">{s.letter}</h3>
              </div>
              <div class="relative flex h-full w-full flex-col items-start justify-center gap-[var(--gap-xs)] lg:flex-row lg:items-center lg:justify-start lg:gap-0">
                <div class="flex w-full flex-col items-start justify-center gap-[var(--gap-xs)] md:h-1/2 lg:h-auto">
                  <h4 class="pr-[var(--padding-base)] text-xl/normal uppercase lg:pr-0">{s.title}</h4>
                  <p class="sm hidden text-ellipsis leading-[135%] text-neutral-500 lg:line-clamp-3">{s.body}</p>
                </div>
                <div class="flex w-full shrink-0 items-end justify-between gap-[var(--gap-xs)] md:h-1/2 md:w-auto md:items-start lg:h-full lg:items-end lg:justify-end lg:gap-0 lg:p-[var(--padding-base)] lg:pl-[var(--padding-xs)]">
                  <p class="sm line-clamp-3 text-ellipsis leading-[135%] text-neutral-500 lg:hidden">{s.body}</p>
                  <button type="button" class="group/button button arrow empty" tabindex="-1" aria-hidden="true">
                    <span class="sr-only">View {s.title} details</span>
                  </button>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<section id="community" class="relative w-full">
  <div
    class="group/section animate-in-view corner-background-top relative flex w-full flex-col items-stretch justify-start gap-[var(--gap-xl)] rounded-[var(--radius-4xl)] fill-white py-[var(--padding-3xl)] pr-8 pl-[var(--padding-md)] transition-mode lg:p-[var(--padding-3xl)] lg:pr-8 dark:fill-dark"
  >
    <wm-shape
      rounded="clamp(1rem, -0.143rem + 1.786vw, 2rem)"
      rounded-mobile="clamp(1rem, 0.421rem + 2.469vw, 2rem)"
      corner-rounded="clamp(0.75rem, -0.107rem + 1.339vw, 1.5rem)"
      corner-rounded-mobile="clamp(0.75rem, -0.107rem + 1.339vw, 1.5rem)"
      corner-size="clamp(4.5rem, -0.071rem + 7.143vw, 8.5rem)"
      corner-size-mobile="clamp(3.5rem, 0.606rem + 12.346vw, 8.5rem)"
      stroke-width="1"
      corner="tr"
    ></wm-shape>
    <div
      class="grid grid-cols-1 place-items-start gap-[var(--gap-xl)] overflow-x-clip border-b border-neutral-200 pb-[var(--padding-xl)] transition-mode lg:grid-cols-[2fr_5fr] lg:grid-rows-1 lg:place-items-end dark:border-neutral-800"
    >
      <div class="flex flex-col items-end justify-end gap-[var(--gap-xl)] sm:flex-row-reverse sm:items-center lg:col-start-2 lg:row-start-1 lg:items-end">
        <svg
          viewBox="0 0 120 120"
          fill="none"
          class="w-[clamp(4rem,1.975rem+8.642vw,7.5rem)] shrink-0 translate-x-[calc(100%+1px)] stroke-[1rem] transition-move group-[.visible]/section:translate-x-0 group-[.visible]/section:delay-500 lg:w-[clamp(4rem,0rem+6.25vw,7.5rem)] lg:self-start dark:text-white"
          aria-hidden="true"
        >
          <path d="M114 6L77.7359 42.5L77.7359 77.5L114 114M6 114L42.2641 77.5L42.2641 42.5L6.00001 6" fill="none" stroke="currentcolor"></path>
        </svg>
        <h2 class="h4 max-w-256 split-heading text-balance text-right leading-none uppercase dark:text-white">
          Join The Best Community in web3
        </h2>
      </div>
      <div class="flex flex-row items-start justify-start justify-self-start self-start lg:col-start-1 lg:row-start-1">
        <p class="split-text sm:text-balance">
          The Avalanche culture goes beyond the chain. Get connected with the founders, investors, artists, gamers, and creators who call Avalanche home.
        </p>
      </div>
    </div>
    <div class="flex flex-col items-stretch justify-start gap-y-2">
      <div class="flex flex-row items-center justify-start">
        <div class="flex flex-1 flex-row items-center justify-between gap-2 sm:justify-start">
          {
            socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener"
                class="group/social flex flex-row items-center justify-start rounded-lg border border-neutral-200 p-[var(--padding-xs)] no-underline transition-mode hover:bg-black dark:border-neutral-800 dark:hover:bg-white"
              >
                <span class="sr-only">Link to {s.label} social</span>
                <div
                  class="flex size-[clamp(2rem,1.421rem+2.469vw,3rem)] flex-row items-center justify-center rounded-[0.625rem] border border-neutral-200 bg-black transition-mode group-hover/social:border-neutral-800 lg:size-[clamp(2rem,0.857rem+1.786vw,3rem)] lg:rounded-[clamp(0.375rem,0.089rem+0.446vw,0.625rem)] dark:border-neutral-800 dark:bg-white dark:group-hover/social:border-neutral-200"
                >
                  <img
                    src={s.icon}
                    alt=""
