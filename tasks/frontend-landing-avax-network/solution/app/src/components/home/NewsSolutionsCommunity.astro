const socials = [
  { label: "X", href: "https://x.com/avax", icon: "/_astro/twitter_Z26kwQC.svg" },
  { label: "Arena", href: "https://arena.social/avax", icon: "/images/icons/the-arena-logo_Z1k4eOU.svg" },
  { label: "Discord", href: "https://discord.gg/avax", icon: "/_astro/discord_Z21UXRB.svg" },
  { label: "YouTube", href: "https://www.youtube.com/Avalancheavax", icon: "/images/icons/youtube_ZSk6Q3.svg" },
  { label: "Reddit", href: "https://www.reddit.com/r/Avax/", icon: "/images/icons/reddit_Z29KPHH.svg" },
  { label: "LinkedIn", href: "https://www.linkedin.com/company/avalancheavax/", icon: "/images/icons/linkedin_2ba9AL.svg" },
