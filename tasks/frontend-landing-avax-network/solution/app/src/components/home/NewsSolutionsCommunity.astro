    body: "High-performance, immersive Web3 gaming powered by Avalanche's speed and scale.",
    href: "/gaming",
    img: "/_astro/9_R8Bdu.webp",
  },
  {
    letter: "E",
    title: "Enterprise and Consumer Apps",
    body: "Scalable solutions with real-world utility, from logistics to loyalty programs.",
    href: "/enterprise",
    img: "/_astro/1_ZGR4fw.webp",
  },
  {
    letter: "D",
    title: "Decentralized Finance (DeFi)",
    body: "Fast, low-cost DeFi programs powering the future of financial systems.",
    href: "/defi",
    img: "/_astro/2_2oNQIv.webp",
  },
  {
    letter: "N",
    title: "NFTs, Arts, and Culture",
    body: "The Avalanche network enables community building and connection for creatives.",
    href: "/nft",
    img: "/_astro/10_Z2fuRCR.webp",
  },
  {
    letter: "I",
