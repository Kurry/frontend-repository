<script>
  import Swiper from "swiper";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import gsap from "gsap";
  import "swiper/css";
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll<HTMLElement>(".swiper").forEach((el) => {
    const id = el.id?.replace("swiper-", "") || "blog";
    const next = document.querySelectorAll(`.swiper-${id}-button-next`);
    const prev = document.querySelectorAll(`.swiper-${id}-button-prev`);
    const labels = document.getElementById(`${id}-labels`);
    const swiper = new Swiper(el, {
      slidesPerView: "auto",
      initialSlide: 0,
      spaceBetween: 0,
      on: {
        reachBeginning: () => {
          prev.forEach((b) => ((b as HTMLButtonElement).disabled = true));
          labels?.classList.add("is-beginning");
          el.classList.add("is-beginning");
        },
        reachEnd: () => {
          next.forEach((b) => ((b as HTMLButtonElement).disabled = true));
          el.classList.add("is-end");
        },
        activeIndexChange: (s) => {
          if (!s.isBeginning) {
            prev.forEach((b) => ((b as HTMLButtonElement).disabled = false));
            labels?.classList.remove("is-beginning");
            el.classList.remove("is-beginning");
          }
          if (!s.isEnd) {
            next.forEach((b) => ((b as HTMLButtonElement).disabled = false));
            el.classList.remove("is-end");
          }
        },
        init: () => {
          prev.forEach((b) => ((b as HTMLButtonElement).disabled = true));
        },
      },
    });
    next.forEach((b) => b.addEventListener("click", () => swiper.slideNext()));
    prev.forEach((b) => b.addEventListener("click", () => swiper.slidePrev()));
    ScrollTrigger.create({
      trigger: el,
      start: "top bottom",
      onLeaveBack: () => swiper.slideTo(0),
    });
  });
</script>
