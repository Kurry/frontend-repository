---
// Session leads panel — sits between Contact and the Footer. Compiles an
// in-session log of newsletter + contact submissions into a live-updating
// astra-session-leads.json artifact with Download / Copy / Undo / Import.
---

<section id="session-leads" class="relative w-full scroll-mt-[var(--navbar-height)]">
  <div
    class="animate-in-view relative flex w-full flex-col items-stretch gap-[var(--gap-lg)] rounded-[var(--radius-4xl)] border border-neutral-200 px-[var(--padding-md)] py-[var(--padding-2xl)] transition-mode lg:p-[var(--padding-2xl)] dark:border-neutral-800 dark:bg-dark"
  >
    <div class="flex flex-col items-start justify-between gap-[var(--gap-base)] sm:flex-row sm:items-end">
      <div class="flex flex-col items-start gap-[var(--gap-xs)]">
        <h2 class="h4 leading-none uppercase dark:text-white">Session leads</h2>
        <p class="text-[var(--text-sm)] text-neutral-500 dark:text-neutral-300">
          Newsletter and contact submissions you make in this session appear here as a downloadable
          <code>astra-session-leads.json</code> artifact.
        </p>
      </div>
      <p class="shrink-0 text-[var(--text-sm)] text-neutral-500 dark:text-neutral-300">
        <span id="session-leads-count" class="text-[var(--text-2xl)] font-black text-red">0</span> leads
      </p>
    </div>

    <div class="flex flex-row flex-wrap items-center gap-[var(--gap-xs)]">
      <button
        id="session-leads-download"
        type="button"
        class="rounded-lg border border-neutral-300 px-[var(--padding-base)] py-2 font-aeonik text-xs font-bold uppercase text-black transition-mode hover:bg-neutral-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-900"
      >
        Download JSON
      </button>
      <button
        id="session-leads-copy"
        type="button"
        class="rounded-lg border border-neutral-300 px-[var(--padding-base)] py-2 font-aeonik text-xs font-bold uppercase text-black transition-mode hover:bg-neutral-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-900"
      >
        <span data-copy-label>Copy JSON</span>
      </button>
      <button
        id="session-leads-undo"
        type="button"
        class="rounded-lg border border-neutral-300 px-[var(--padding-base)] py-2 font-aeonik text-xs font-bold uppercase text-black transition-mode hover:bg-neutral-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red disabled:cursor-not-allowed disabled:opacity-40 dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-900"
        disabled
      >
        Undo last lead
      </button>
      <label
        for="session-leads-import"
        class="cursor-pointer rounded-lg border border-neutral-300 px-[var(--padding-base)] py-2 font-aeonik text-xs font-bold uppercase text-black transition-mode hover:bg-neutral-100 focus-within:outline-2 focus-within:outline-offset-2 focus-within:outline-red dark:border-neutral-700 dark:text-white dark:hover:bg-neutral-900"
      >
        Import leads JSON
        <input id="session-leads-import" type="file" accept="application/json,.json" class="sr-only" />
      </label>
    </div>

    <p
      id="session-leads-status"
      role="status"
      aria-live="polite"
      class="min-h-[1.25rem] text-[var(--text-sm)] text-neutral-500 dark:text-neutral-300"
    ></p>

    <ul id="session-leads-list" class="flex flex-col gap-[var(--gap-xs)]">
      <li id="session-leads-empty" class="text-[var(--text-sm)] text-neutral-500 dark:text-neutral-400">
        No leads yet — complete the newsletter or contact form above and they will be logged here.
      </li>
    </ul>

    <details class="mt-[var(--gap-xs)]">
      <summary class="cursor-pointer text-[var(--text-sm)] font-bold text-neutral-500 uppercase dark:text-neutral-300">
        astra-session-leads.json preview
      </summary>
      <pre
        id="session-leads-preview"
        class="mt-[var(--gap-xs)] max-h-80 overflow-auto rounded-lg bg-neutral-100 p-[var(--padding-base)] font-mono text-xs text-black dark:bg-neutral-900 dark:text-white"
      ></pre>
    </details>
  </div>
</section>

<script>
  import store, { type Lead } from "../../scripts/session-leads";

  const countEl = document.getElementById("session-leads-count");
  const listEl = document.getElementById("session-leads-list");
  const emptyEl = document.getElementById("session-leads-empty");
  const previewEl = document.getElementById("session-leads-preview");
  const statusEl = document.getElementById("session-leads-status");
  const undoBtn = document.getElementById("session-leads-undo") as HTMLButtonElement | null;
  const downloadBtn = document.getElementById("session-leads-download");
  const copyBtn = document.getElementById("session-leads-copy");
  const copyLabel = copyBtn?.querySelector("[data-copy-label]") as HTMLElement | null;
  const importInput = document.getElementById("session-leads-import") as HTMLInputElement | null;

  const escapeHtml = (s: string) =>
    s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c] || c);

  const rowHtml = (lead: Lead) => {
    const p = lead.payload as Record<string, unknown>;
    const who = [p.firstname, p.lastname].filter(Boolean).join(" ") || String(p.email || "lead");
    return `<li class="flex flex-row items-center justify-between gap-4 rounded-lg border border-neutral-200 px-4 py-2 text-[var(--text-sm)] dark:border-neutral-800">
      <span class="flex flex-col">
        <span class="font-bold uppercase text-red">${escapeHtml(lead.kind)}</span>
        <span class="dark:text-white">${escapeHtml(who)}</span>
      </span>
      <span class="text-neutral-500 dark:text-neutral-400">${escapeHtml(String(p.email || ""))}</span>
    </li>`;
  };

  const render = (leads: Lead[]) => {
    if (countEl) countEl.textContent = String(leads.length);
    if (undoBtn) undoBtn.disabled = leads.length === 0;
    if (listEl) {
      if (leads.length === 0) {
        listEl.innerHTML = "";
        if (emptyEl) listEl.appendChild(emptyEl);
      } else {
        listEl.innerHTML = leads.map(rowHtml).join("");
      }
    }
    if (previewEl) previewEl.textContent = store.exportText();
  };

  store.subscribe(render);

  const flashStatus = (msg: string) => {
    if (!statusEl) return;
    statusEl.textContent = msg;
  };

  downloadBtn?.addEventListener("click", () => {
    const text = store.exportText();
    const blob = new Blob([text], { type: "application/json" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = "astra-session-leads.json";
    document.body.appendChild(a);
    a.click();
    a.remove();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
    flashStatus("Downloaded astra-session-leads.json");
  });

  copyBtn?.addEventListener("click", async () => {
    const text = store.exportText();
    try {
      await navigator.clipboard.writeText(text);
    } catch {
      const ta = document.createElement("textarea");
      ta.value = text;
      document.body.appendChild(ta);
      ta.select();
      try {
        document.execCommand("copy");
      } catch {}
      ta.remove();
    }
    if (copyLabel) {
      copyLabel.textContent = "Copied";
      flashStatus("Copied astra-session-leads.json to clipboard");
      setTimeout(() => {
        copyLabel.textContent = "Copy JSON";
      }, 2500);
    }
  });

  undoBtn?.addEventListener("click", () => {
    const removed = store.undo();
    flashStatus(removed ? `Removed last ${removed.kind} lead` : "No leads to undo");
  });

  importInput?.addEventListener("change", async () => {
    const file = importInput.files?.[0];
    if (!file) return;
    const text = await file.text();
    const res = store.importDoc(text);
    flashStatus(res.ok ? "Imported session leads" : `Import failed: ${res.error}`);
    importInput.value = "";
  });
</script>
