---
import '../styles/global.css';
import '@fontsource-variable/dm-sans';
import '@fontsource-variable/space-grotesk';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <div id="root">
      <slot />
    </div>
  </body>
</html>
