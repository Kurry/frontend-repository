{
  "name": "mosbyfiles-oracle",
  "version": "1.0.0",
  "private": true,
  "description": "Mosby's Files — offline static oracle reconstruction (10 routes, WebMCP surface).",
  "scripts": {
    "start": "npx --yes serve@14 -l 3000 -s .",
    "verify:build": "node -e \"var f=require('fs');['index.html','app.js','app.css','assets/manifest.json'].forEach(function(p){if(!f.existsSync(p)){throw new Error('missing '+p)}});console.log('verify:build ok')\""
  }
}
