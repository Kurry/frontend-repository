{
  "name": "hildenkaira-oracle",
  "private": true,
  "version": "2.0.0",
  "description": "Natively authored Astro + Tailwind + GSAP reference implementation of the Hildén & Kaira homepage",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev --host 0.0.0.0 --port ${PORT:-3000}",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "verify:build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "start": "HOST=0.0.0.0 PORT=${PORT:-3000} node ./dist/server/entry.mjs",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.2",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.9",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "nanostores": "^1.4.0",
    "serve": "14.2.4",
    "swiper": "^14.0.5",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1"
  }
}
