---
import data from "../data/home.json";
import Button from "./Button.astro";
const { h1, lead, buttons, floating } = data.hero;
// Twelve original chrome letterforms spelling the fictional wordmark
// "Cinder & Bloom" (C i n d e r & B l o o m). Each is an inline SVG so the
// bundled editorial face fills it; per-letter widths compose the wordmark.
const CHARS = ["C", "i", "n", "d", "e", "r", "&", "B", "l", "o", "o", "m"];
const WIDTHS = [74, 30, 64, 64, 60, 42, 82, 74, 30, 62, 62, 96];
---
<header class="section_hero" data-gsap-ignore>
  <svg width="0" height="0" aria-hidden="true" focusable="false" style="position:absolute">
    <defs>
      <linearGradient id="chromeHero" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#fbfbfb"/>
        <stop offset="0.32" stop-color="#c9c9c9"/>
        <stop offset="0.5" stop-color="#f2f2f2"/>
        <stop offset="0.7" stop-color="#8f8f8f"/>
        <stop offset="1" stop-color="#d6d6d6"/>
      </linearGradient>
    </defs>
  </svg>
  <div class="hero-home_wrapper">
    <div class="hero-home_body">
      <div class="padding-global">
        <div class="container-col-12">
          <div class="hero-home_content" data-hero-content>
            <h1 class="heading-xl" data-gsap-ignore data-split-visible>{h1}</h1>
            <div class="hero-home_text-wrap">
              <p class="paragraph-m" data-split-visible>{lead}</p>
            </div>
            <div class="btn-group">
              <div class="btn-group-1">
                <Button label={buttons[0].label} href={buttons[0].href} variant="secondary" />
              </div>
              <div class="btn-group-2">
                <Button label={buttons[1].label} href={buttons[1].href} variant="primary" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="hero-home_logo" data-hero-logo role="img" aria-label="Cinder & Bloom">
      {CHARS.map((ch, i) => (
        <svg
          class={`hero-home_logo-item is-${i + 1}`}
          viewBox={`0 0 ${WIDTHS[i]} 100`}
          aria-hidden="true"
          focusable="false"
          data-logo-index={i}
        >
          <text
            x="2"
            y="82"
            textLength={WIDTHS[i] - 4}
            lengthAdjust="spacingAndGlyphs"
            fill="url(#chromeHero)"
            style="font-family:var(--_fonts---fonts--heading);font-weight:400;font-size:96px;"
          >{ch}</text>
        </svg>
      ))}
    </div>

    <div class="hero-home_bg" data-hero-bg>
      <div class="hero-home_collection">
        <div class="hero-home_list" role="list">
          {floating.map((f) => (
            <div class="hero-home_item" role="listitem" data-hero-item data-zone={f.zone}>
              <div class="hero-home_media">
                <img class="image" src={f.src} alt="" loading="eager" />
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="hero-home_pageload-bg" data-pageload-bg></div>
  </div>
</header>
