---
import data from "../data/home.json";
const f = data.footer;
// Original chrome letterforms for the fictional "Cinder & Bloom" wordmark.
const CHARS = ["C", "i", "n", "d", "e", "r", "&", "B", "l", "o", "o", "m"];
const WIDTHS = [74, 30, 64, 64, 60, 42, 82, 74, 30, 62, 62, 96];
const icons: Record<string, string> = {
  spotify: `<svg class="btn-icon-content__social" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm4.4 14.5a.7.7 0 0 1-1 .2c-2.6-1.6-5.9-2-9.8-1.1a.7.7 0 1 1-.3-1.4c4.2-1 7.9-.5 10.8 1.3.3.2.4.7.3 1Zm1.2-2.9a.9.9 0 0 1-1.2.3c-3-1.8-7.5-2.4-11-1.3a.9.9 0 0 1-.5-1.7c4-1.2 9-.6 12.4 1.5.4.2.5.8.3 1.2Zm.1-3a1 1 0 0 1-1.4.4C13 9 8 8.8 4.9 9.8a1 1 0 1 1-.6-2c3.6-1.1 9.2-.9 13 1.4.5.3.7 1 .4 1.4Z"/></svg>`,
  youtube: `<svg class="btn-icon-content__social" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M22 8.2a3 3 0 0 0-2.1-2.1C18 5.6 12 5.6 12 5.6s-6 0-7.9.5A3 3 0 0 0 2 8.2 31 31 0 0 0 1.6 12c0 1.3.1 2.6.4 3.8a3 3 0 0 0 2.1 2.1c1.9.5 7.9.5 7.9.5s6 0 7.9-.5a3 3 0 0 0 2.1-2.1c.3-1.2.4-2.5.4-3.8s-.1-2.6-.4-3.8ZM10 15V9l5.2 3L10 15Z"/></svg>`,
  apple: `<svg class="btn-icon-content__social" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm0 4.4a3.3 3.3 0 0 1 3.3 3.3c0 1.2-.6 2.2-1.6 2.8.2.2.3.5.3.9l.6 4a1 1 0 0 1-1 1.2h-3.2a1 1 0 0 1-1-1.2l.6-4c0-.4.1-.7.3-.9a3.3 3.3 0 0 1-1.6-2.8A3.3 3.3 0 0 1 12 6.4Zm0 2a1.4 1.4 0 1 0 0 2.8 1.4 1.4 0 0 0 0-2.8Z"/></svg>`,
  instagram: `<svg class="btn-icon-content__social" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"/></svg>`,
  tiktok: `<svg class="btn-icon-content__social" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M16.6 3c.4 1.9 1.7 3.4 3.9 3.7v3c-1.5 0-2.8-.5-3.9-1.3v6.1a5.9 5.9 0 1 1-5.9-5.9c.3 0 .7 0 1 .1v3.1a2.8 2.8 0 1 0 1.9 2.7V3h3Z"/></svg>`,
  facebook: `<svg class="btn-icon-content__social" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M13.5 21v-7h2.4l.4-2.8h-2.8V9.4c0-.8.2-1.4 1.4-1.4h1.5V5.5c-.3 0-1.2-.1-2.2-.1-2.2 0-3.7 1.3-3.7 3.8v2H8v2.8h2.5v7h3Z"/></svg>`,
};
---
<footer class="footer theme-chrome" data-gsap-ignore>
  <div class="padding-global">
    <div class="container-col-12">
      <div class="footer_wrapper">
        <svg width="0" height="0" aria-hidden="true" focusable="false" style="position:absolute">
          <defs>
            <linearGradient id="chromeFoot" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="#fbfbfb"/>
              <stop offset="0.32" stop-color="#c9c9c9"/>
              <stop offset="0.5" stop-color="#f2f2f2"/>
              <stop offset="0.7" stop-color="#8f8f8f"/>
              <stop offset="1" stop-color="#d6d6d6"/>
            </linearGradient>
          </defs>
        </svg>
        <div class="footer-logo" data-footer-logo role="img" aria-label="Cinder & Bloom">
          {CHARS.map((ch, i) => (
            <svg
              class={`footer-logo_item is-${i + 1}`}
              viewBox={`0 0 ${WIDTHS[i]} 100`}
              aria-hidden="true"
              focusable="false"
            >
              <text
                x="2"
                y="82"
                textLength={WIDTHS[i] - 4}
                lengthAdjust="spacingAndGlyphs"
                fill="url(#chromeFoot)"
                style="font-family:var(--_fonts---fonts--heading);font-weight:400;font-size:96px;"
              >{ch}</text>
            </svg>
          ))}
        </div>
        <div class="footer-main">
          <div class="footer-main_top">
            <div class="footer-main_sitemap">
              <h2 class="footer-main_title" data-split-visible>{f.sitemapTitle}</h2>
              <div class="footer-main_sitemap-links">
                {f.sitemap.map((l, i) => (
                  <a class={`footer-main_link w-inline-block${i === 0 ? " w--current" : ""}`} href={l.href}>
                    <div class="paragraph-m" data-split-visible>{l.label}</div>
                  </a>
                ))}
              </div>
            </div>
            <div class="footer-main_cards">
              <div class="footer-main_card">
                <h2 class="footer-main_title" data-split-visible>{f.podcast.title}</h2>
                <img class="footer-main_card-img" src={f.podcast.emoji} alt="Podcast Emoji" loading="lazy" />
                <div class="footer-main_card-links">
                  {f.podcast.links.map((l) => (
                    <a class="btn-icon-link w-inline-block theme-dark" href={l.href} aria-label={`${l.kind} (Cinder & Bloom)`}>
                      <div class="btn-icon-content is-icon">
                        <div class="btn-icon-content__mask" set:html={icons[l.kind]} />
                        <div class="btn-icon-content__bg is-lime" data-button-anim-target></div>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
              <div class="footer-main_card">
                <h2 class="footer-main_title" data-split-visible>{f.social.title}</h2>
                <img class="footer-main_card-img is-social" src={f.social.emoji} alt="Metallic Heart Emoji" loading="lazy" />
                <div class="footer-main_card-links">
                  {f.social.links.map((l) => (
                    <a class="btn-icon-link w-inline-block theme-dark" href={l.href} aria-label={`${l.kind} (Cinder & Bloom)`}>
                      <div class="btn-icon-content is-icon">
                        <div class="btn-icon-content__mask" set:html={icons[l.kind]} />
                        <div class="btn-icon-content__bg is-lime" data-button-anim-target></div>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </div>
          <div class="footer-main_bottom">
            <div class="footer-main_bottom-col">
              <div class="paragraph-s opacity-60" data-split-visible>
                © <span class="current-year" current-year>2026</span> All rights reserved
              </div>
              <div class="legals-collection">
                <div class="legals-list">
                  {f.legal.map((l) => (
                    <a class="footer-bottom_link w-inline-block" href={l.href}>
                      <div class="paragraph-s" data-split-visible>{l.label}</div>
                    </a>
                  ))}
                </div>
              </div>
            </div>
            <a class="footer-bottom_link w-inline-block" href={f.credit.href}>
              <div class="paragraph-s" data-split-visible>{f.credit.label}</div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="footer-bg theme-chrome"></div>
</footer>
