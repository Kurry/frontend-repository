---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";
import ShortlistPanel from "../components/ShortlistPanel.astro";
import CommandPalette from "../components/CommandPalette.astro";
import DiscoveryBrief from "../components/DiscoveryBrief.astro";

interface Props {
  title?: string;
  bodyClass?: string;
}
const { title = "Cinder & Bloom", bodyClass = "" } = Astro.props;

const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Cinder & Bloom",
  url: "/",
  slogan: "We will 10x your social presence or work for free until it's done.",
  review: [
    {
      "@type": "Review",
      author: { "@type": "Person", name: "Marcus Virtanen" },
      reviewBody:
        "Results speak for themselves. We reached a massive audience and broke into traditional media's awareness in just a few months.",
    },
    {
      "@type": "Review",
      author: { "@type": "Person", name: "Aino Laine" },
      reviewBody:
        "Cinder & Bloom has succeeded in bringing the expertise at the core of our work to a wide audience, and the results have followed.",
    },
  ],
};
---
<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/webclip.png" />
    <link rel="alternate" hreflang="en-GB" href="/" />
    <link rel="alternate" hreflang="x-default" href="/" />
    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    <script is:inline>
      // Motion gate + Safari class, before first paint. Only add the
      // js-motion hiding/animation class when motion is allowed; otherwise
      // mark reduce-motion so CSS shows every section in its settled state.
      var _rm = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (_rm) {
        document.documentElement.classList.add("reduce-motion");
      } else {
        document.documentElement.classList.add("js-motion");
      }
      if (/^((?!chrome|android).)*safari/i.test(navigator.userAgent)) {
        document.documentElement.classList.add("is-safari");
      }
    </script>
    <noscript>
      <style>
        .js-motion main :is(h1, h2, h3, p), .js-motion footer :is(h1, h2, h3, p) { visibility: visible !important; }
        .hero-home_pageload-bg { display: none; }
      </style>
    </noscript>
  </head>
  <body class={bodyClass}>
    <div class="page-wrapper">
      <CookieBanner />
      <ShortlistPanel />
      <CommandPalette />
      <DiscoveryBrief />
      <Nav />
      <main class="main-wrapper">
        <slot />
      </main>
      <Footer />
    </div>
    <script>
      import "../scripts/main.js";
    </script>
    <script src="../scripts/webmcp.ts"></script>
  </body>
</html>
