---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";

interface Props {
  title?: string;
  bodyClass?: string;
}
const { title = "Hildén & Kaira", bodyClass = "" } = Astro.props;

const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Hildén & Kaira",
  url: "https://www.hildenkaira.fi/",
  slogan: "We will 10x your organic presence or work for free until it's done.",
  sameAs: [
    "https://instagram.com/hildenkaira",
    "https://tiktok.com/@hildenkaira",
    "https://youtube.com/@hildenkaira",
    "https://www.facebook.com/hildenkaira/",
  ],
  review: [
    {
      "@type": "Review",
      author: { "@type": "Person", name: "Nea Mertsalmi" },
      reviewBody:
        "Results speak for themselves. We've reached a massive audience and broken into traditional media's awareness in just a few months.",
    },
    {
      "@type": "Review",
      author: { "@type": "Person", name: "Alma Rapakko" },
      reviewBody:
        "Hildén & Kaira has succeeded in bringing the expertise and knowledge at the core of our work to a wide audience, and the results have followed.",
    },
  ],
};
---
<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/webclip.png" />
    <link rel="alternate" hreflang="en-GB" href="/" />
    <link rel="alternate" hreflang="x-default" href="/" />
    <link rel="preload" href="/fonts/PPEditorialNew-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/PPNeueMontreal-Medium.woff2" as="font" type="font/woff2" crossorigin />
    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    <script is:inline>
      // Motion gate + Safari class, before first paint.
      document.documentElement.classList.add("js-motion");
      if (/^((?!chrome|android).)*safari/i.test(navigator.userAgent)) {
        document.documentElement.classList.add("is-safari");
      }
    </script>
    <noscript>
      <style>
        .js-motion main :is(h1, h2, h3, p), .js-motion footer :is(h1, h2, h3, p) { visibility: visible !important; }
        .hero-home_pageload-bg { display: none; }
      </style>
    </noscript>
  </head>
  <body class={bodyClass}>
    <div class="page-wrapper">
      <CookieBanner />
      <Nav />
      <main class="main-wrapper">
        <slot />
      </main>

      <Footer />

      <!-- Command Palette -->
      <dialog id="command-palette" class="theme-dark-grey p-4 m-auto rounded-lg backdrop:bg-black/50" style="max-width: 480px; width: 100%;">
        <div class="flex flex-col gap-4">
          <input type="text" placeholder="Search commands..." id="cmd-search" class="form-input w-full" />
          <div class="flex flex-col gap-2">
            <button class="button variant-secondary" id="cmd-export" data-cmd="export">Export brief</button>
            <button class="button variant-secondary" id="cmd-jump" data-cmd="jump">Jump to services</button>
          </div>
        </div>
      </dialog>

      <!-- Discovery Brief -->
      <dialog id="discovery-brief" class="theme-white p-8 m-auto rounded-lg backdrop:bg-black/50 overflow-y-auto" style="max-width: 600px; width: 100%; max-height: 90vh;">
        <div class="flex justify-between items-center mb-4">
          <h2 class="heading-style-h2">Discovery brief — Cinder & Bloom</h2>
          <button id="brief-close" class="button variant-secondary">Close</button>
        </div>

        <div class="flex gap-4 mb-4">
          <button id="tab-json" class="font-bold underline">JSON</button>
          <button id="tab-md">Markdown</button>
        </div>

        <div id="brief-json-view" class="mb-4">
          <textarea id="brief-json-content" class="form-input w-full font-mono text-sm" rows="12"></textarea>
          <div id="import-error" class="text-red-500 text-sm mt-2 hidden"></div>
        </div>

        <div id="brief-md-view" class="mb-4 hidden">
          <textarea id="brief-md-content" class="form-input w-full font-mono text-sm" rows="12" readonly></textarea>
        </div>

        <div class="flex gap-2">
          <button id="brief-download" class="button variant-primary">Download</button>
          <button id="brief-copy" class="button variant-secondary">Copy</button>
          <button id="brief-import" class="button variant-secondary">Import</button>
        </div>
        <div id="copy-confirm" class="text-green-500 text-sm mt-2 opacity-0 transition-opacity">Copied!</div>
      </dialog>

      <!-- Shortlist Panel -->
      <dialog id="shortlist-panel" class="theme-white p-6 m-auto rounded-lg backdrop:bg-black/50" style="max-width: 400px; width: 100%;">
        <div class="flex justify-between items-center mb-4">
          <h2 class="heading-style-h2">Shortlist</h2>
          <button id="shortlist-close" class="button variant-secondary">Close</button>
        </div>
        <div id="shortlist-list" class="flex flex-col gap-2 mb-4"></div>
      </dialog>

    </div>
    <script>
      import "../scripts/main.js";
    </script>
    <script src="../scripts/webmcp.ts"></script>
  </body>
</html>
