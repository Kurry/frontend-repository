---
import Layout from "../../../layouts/Layout.astro";
import Navigation from "../../../components/Navigation.astro";
import Footer from "../../../components/Footer.astro";
import NewsletterContact from "../../../components/forms/NewsletterContact.astro";
import pressPosts from "../../../data/press-posts.json";

export function getStaticPaths() {
  return pressPosts.map((post) => ({ params: { slug: post.slug } }));
}

const slug = Astro.params.slug ?? "";
const post = pressPosts.find((p) => p.slug === slug);
if (!post) {
  return Astro.redirect("/about/press");
}
---

<Layout title={`${post.title} | Avalanche Press`} description={post.title}>
  <Navigation />
  <main class="pt-[var(--navbar-height)]">
    <article class="group/section animate-in-view mx-[var(--padding-base)] mt-[var(--padding-base)] rounded-[var(--radius-4xl)] bg-dark p-[var(--padding-xl)] lg:p-[var(--padding-3xl)]">
      <p class="text-[var(--text-sm)] uppercase tracking-widest text-neutral-500">
        <a href="/about/press" class="hover:text-red">Press</a>
      </p>
      <h1 class="font-aeonik split-heading mt-4 max-w-[22ch] text-[var(--text-5xl)] font-black leading-none">{post.title}</h1>
      <p class="split-text mt-6 max-w-[65ch] text-[var(--text-base)] text-neutral-300 opacity-0">
        Press route mirrored from sitemap. Full article body expands when harvest HTML or CMS API is available.
      </p>
    </article>
    <NewsletterContact />
  </main>
  <Footer />
</Layout>
