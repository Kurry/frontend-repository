{
  "name": "@zto/webmcp-contracts",
  "version": "1.0.0",
  "description": "Six-contract WebMCP runtime for zto-webmcp-v1 (framework-neutral core + lifecycle adapters)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters/svelte": {
      "types": "./dist/adapters/svelte.d.ts",
      "import": "./dist/adapters/svelte.js"
    },
    "./adapters/vue": {
      "types": "./dist/adapters/vue.d.ts",
      "import": "./dist/adapters/vue.js"
    },
    "./adapters/angular": {
      "types": "./dist/adapters/angular.d.ts",
      "import": "./dist/adapters/angular.js"
    },
    "./adapters/react": {
      "types": "./dist/adapters/react.d.ts",
      "import": "./dist/adapters/react.js"
    },
    "./adapters/vanilla": {
      "types": "./dist/adapters/vanilla.d.ts",
      "import": "./dist/adapters/vanilla.js"
    },
    "./assignment-map.schema.json": "./specs/assignment-map.schema.json"
  },
  "files": [
    "dist",
    "specs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "vue": "^3.5.0",
    "@angular/core": "^19.0.0 || ^20.0.0",
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "vue": { "optional": true },
    "@angular/core": { "optional": true },
    "svelte": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "react": "^19.1.0",
    "svelte": "^5.28.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2",
    "vue": "^3.5.13"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "private": true
}
