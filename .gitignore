.playwright-mcp/

# Python virtualenvs
.venv/
venv/

# Regenerable capture output at repo root (installed copies in tasks/*/environment/ ARE tracked)
/reference-screenshots/

/.harden-locks

# Built oracle output — rebuilt by verify:build (and, for the screenshot
# capture harness, on demand), never committed. The general dist/build/out/
# .next/.nuxt/.svelte-kit/storybook-static patterns above already cover
# these; the explicit rules below are a scoped safety net so a stray
# `git add -f` under an oracle app can't re-commit build output.
tasks/*/solution/app/dist/
tasks/*/solution/app/build/
tasks/*/solution/app/out/
tasks/*/solution/app/.next/
tasks/*/solution/app/.nuxt/
tasks/*/solution/app/.svelte-kit/
tasks/*/solution/app/storybook-static/

# Stray dev/QA captures at oracle app roots (reference screenshots live in
# tasks/*/environment/reference-screenshots/, which stays tracked)
tasks/*/solution/app/smoke*.png
tasks/*/solution/app/screenshot*.png
tasks/*/solution/app/verification*.png

# Transient git worktrees (jules teleport / agent checkouts)
.worktrees/

# Bugbot review-context files are tracked; everything else under .cursor/ stays ignored
!**/.cursor/
**/.cursor/*
!**/.cursor/BUGBOT.md
