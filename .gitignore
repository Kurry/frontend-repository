# Regenerable capture output at repo root (installed copies in tasks/*/environment/ ARE tracked)
/reference-screenshots/

/.harden-locks

# Built oracle output — rebuilt by verify:build, never committed
tasks/*/solution/app/dist/

# Stray dev/QA captures at oracle app roots (reference screenshots live in
# tasks/*/environment/reference-screenshots/, which stays tracked)
tasks/*/solution/app/smoke*.png
tasks/*/solution/app/screenshot*.png
tasks/*/solution/app/verification*.png

# Transient git worktrees (jules teleport / agent checkouts)
.worktrees/
test-results/
playwright-report/
