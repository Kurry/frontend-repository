{
  "$comment": "Ephemeral Claude Code --strict-mcp-config payload for builders. Pins: Chrome for Testing 151.0.7922.34, Stagehand 3.7.0, @playwright/mcp@0.0.76. Stagehand owns Chrome; Playwright attaches via CDP. Expand $WEBMCP_CDP_* at materialize time (rewardkit ephemeral config).",
  "mcpServers": {
    "stagehand-webmcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@browserbasehq/stagehand@3.7.0",
        "mcp",
        "--env",
        "LOCAL",
        "--chrome-version",
        "151.0.7922.34",
        "--enable-webmcp",
        "--tools",
        "webmcp_session_info,webmcp_list_tools,webmcp_invoke_tool",
        "--disable-tools",
        "act,observe,extract,agent",
        "--cdp-port",
        "$WEBMCP_CDP_PORT"
      ]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@0.0.76",
        "--browser",
        "chromium",
        "--cdp-endpoint",
        "$WEBMCP_CDP_ENDPOINT",
        "--isolated",
        "--output-dir",
        "/logs/agent/screenshots"
      ]
    }
  }
}
